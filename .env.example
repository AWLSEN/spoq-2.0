# ----- Phase 0+ (required) -----
# GLM via Anthropic-compatible endpoint
ANTHROPIC_AUTH_TOKEN=your-glm-key-here
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
ANTHROPIC_DEFAULT_OPUS_MODEL=GLM-4.6
API_TIMEOUT_MS=300000

# ----- Phase 2 (sandbox driver) -----
# "local" (default) = spawn claude-code subprocess in a temp workdir
# "orb"             = dispatch to Orb Cloud sandbox (TODO: auth pending)
SANDBOX_DRIVER=local

# ----- JIT capability backend: Composio -----
# Single API key fronts 200+ toolkits (Gmail, Calendar, Slack, Notion,
# Linear, GitHub, Stripe, Calendly, ...) with native MCP + per-user isolation.
# Sign up free at app.composio.dev → Settings → API Keys.
COMPOSIO_API_KEY=ak_your_key_here

# Optional BYOC (for "SPOQ"-branded consent screens before launch):
# COMPOSIO_GMAIL_AUTH_CONFIG=ac_...

# ----- Phase 6 (judge upgrade) -----
# When set, the canonical judge uses Claude Opus via api.anthropic.com
# instead of the GLM self-judge fallback.
# ANTHROPIC_JUDGE_KEY=

# ----- Phase 7 (billing) -----
# STRIPE_PRICE_PLUS=
# STRIPE_PRICE_DEVELOPER=
# STRIPE_WEBHOOK_SECRET=

# ----- Phase 8 (telemetry) -----
# NEXT_PUBLIC_POSTHOG_KEY=
# SENTRY_DSN=
